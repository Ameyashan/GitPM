# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# GitHub OAuth (configured in Supabase Auth dashboard)
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Vercel Integration
VERCEL_CLIENT_ID=your_vercel_integration_client_id
VERCEL_CLIENT_SECRET=your_vercel_integration_client_secret

# Token encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your_64_character_hex_encryption_key

# Resend (transactional email)
RESEND_API_KEY=your_resend_api_key

# Cron job protection (generate a random secret)
CRON_SECRET=your_random_cron_secret

# Thumbnail generation (Puppeteer)
# In production (Vercel): leave unset — @sparticuz/chromium-min downloads Chromium automatically
# In local development: set to your local Chrome path to skip the remote download
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome
CHROME_EXECUTABLE_PATH=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
