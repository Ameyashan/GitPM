# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# GitHub OAuth (configured in Supabase Auth dashboard)
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Vercel Integration
VERCEL_CLIENT_ID=your_vercel_integration_client_id
VERCEL_CLIENT_SECRET=your_vercel_integration_client_secret

# Token encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your_64_character_hex_encryption_key

# Resend (transactional email)
RESEND_API_KEY=your_resend_api_key

# Cron job protection (generate a random secret)
CRON_SECRET=your_random_cron_secret

# Thumbnail generation (Puppeteer)
# In production (Vercel): leave unset — @sparticuz/chromium-min downloads Chromium automatically
# In local development: set to your local Chrome path to skip the remote download
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/google-chrome
CHROME_EXECUTABLE_PATH=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (error monitoring — https://sentry.io)
# Create a Next.js project in Sentry, then copy the DSN from Settings > Client Keys
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
# Used by withSentryConfig in next.config.mjs to upload source maps (CI/Vercel only)
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=your_sentry_project_slug
# Generate at https://sentry.io/settings/auth-tokens/ (scope: project:releases, org:read)
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# PostHog (product analytics — https://posthog.com)
# Create a project in PostHog; find the key under Project Settings > Project API Key
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
# Use app.posthog.com (US) or eu.posthog.com (EU) depending on your data region
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Rate limiting (post-launch — add after setting up Upstash Redis)
# See the TODO block in middleware.ts for full setup instructions
# UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
# UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
